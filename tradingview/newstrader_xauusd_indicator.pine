//@version=5
indicator("NewsTrader XAUUSD Signal Proxy", shorttitle="NT XAUUSD", overlay=true, max_labels_count=500)

// ----------------------------
// Inputs
// ----------------------------
headlineInput = input.string("", "Latest headline text")
sourceInput = input.string("manual", "Headline source")
showDebug = input.bool(true, "Show debug label")
minConfidence = input.float(0.55, "Min confidence to display signal", minval=0.0, maxval=1.0, step=0.01)

// ----------------------------
// Token sets (mirrors Python RuleBasedXAUUSDPolicy)
// ----------------------------
var string[] buyTokens = array.from(
     "dovish", "cuts", "cut", "safe-haven", "escalation", "sanctions", "banking stress", "gold buying"
)

var string[] sellTokens = array.from(
     "hawkish", "hike", "hikes", "strong yields", "de-escalation", "ceasefire", "risk-on"
)

var string[] impactTokens = array.from(
     "fed", "fomc", "cpi", "nfp", "powell", "war", "attack", "intervention", "tariff", "surprise"
)

// ----------------------------
// Helpers
// ----------------------------
countHits(string text, string[] tokens) =>
    int hits = 0
    for i = 0 to array.size(tokens) - 1
        token = array.get(tokens, i)
        if str.contains(text, token)
            hits += 1
    hits

clamp(float v, float lo, float hi) =>
    math.max(lo, math.min(hi, v))

normalizeWhitespace(string text) =>
    string trimmed = str.trim(text)
    string result = ""
    bool inWhitespace = false
    int len = str.length(trimmed)
    for i = 0 to len - 1
        ch = str.char(trimmed, i)
        bool isWhitespace = ch == " " or ch == "\n" or ch == "\t" or ch == "\r"
        if isWhitespace
            if not inWhitespace
                result += " "
                inWhitespace := true
        else
            result += ch
            inWhitespace := false

headlineClean = str.lower(normalizeWhitespace(headlineInput))
buyHits = countHits(headlineClean, buyTokens)
sellHits = countHits(headlineClean, sellTokens)
impactHits = countHits(headlineClean, impactTokens)

hasDirection = buyHits != sellHits and (buyHits > 0 or sellHits > 0)
side = buyHits > sellHits ? "BUY" : "SELL"
impact = impactHits >= 1 ? "high" : "medium"
size = impact == "high" ? 0.20 : 0.10
tpPips = impact == "high" ? 250 : 150
slPips = 100
confidence = clamp(0.55 + 0.10 * math.abs(buyHits - sellHits) + 0.05 * impactHits, 0.0, 0.95)

signalReady = hasDirection and confidence >= minConfidence

// ----------------------------
// Plotting and labels
// ----------------------------
buyShape = signalReady and side == "BUY"
sellShape = signalReady and side == "SELL"

plotshape(buyShape, title="BUY signal", style=shape.triangleup, location=location.belowbar, color=color.new(color.lime, 0), size=size.small, text="NT BUY")
plotshape(sellShape, title="SELL signal", style=shape.triangledown, location=location.abovebar, color=color.new(color.red, 0), size=size.small, text="NT SELL")

alertcondition(buyShape, title="NewsTrader BUY", message="NewsTrader BUY on {{ticker}} | src=" + sourceInput + " | conf=" + str.tostring(confidence, "#.##"))
alertcondition(sellShape, title="NewsTrader SELL", message="NewsTrader SELL on {{ticker}} | src=" + sourceInput + " | conf=" + str.tostring(confidence, "#.##"))

barColor = buyShape ? color.new(color.lime, 80) : sellShape ? color.new(color.red, 80) : na
barcolor(barColor)

if showDebug and barstate.islast
    directionText = hasDirection ? side : "NO TRADE"
    reasonText = hasDirection ? "rule_match" : (buyHits == 0 and sellHits == 0 ? "no_clear_transmission_path" : "ambiguous_direction")
    labelText = "NewsTrader\n" +
      "source: " + sourceInput + "\n" +
      "direction: " + directionText + "\n" +
      "impact: " + impact + "\n" +
      "size: " + str.tostring(size, "#.00") + "\n" +
      "TP/SL: " + str.tostring(tpPips) + "/" + str.tostring(slPips) + " pips\n" +
      "confidence: " + str.tostring(confidence, "#.##") + "\n" +
      "reason: " + reasonText

    label.new(bar_index, high, labelText, style=label.style_label_down, color=color.new(color.black, 0), textcolor=color.white)
